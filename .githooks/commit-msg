#!/bin/sh
# Drop Co-authored-by / "Made with Cursor" trailers so tooling doesn't
# show up as contributors on GitHub. Keeps the subject and body you wrote.
msg="$1"
[ -f "$msg" ] || exit 0
tmp="${msg}.$$"
grep -viE '^(co-authored-by:.*(cursor|claude|copilot|anthropic|openai|codex|composer)|made.with:?[[:space:]]*cursor)' "$msg" > "$tmp" && mv "$tmp" "$msg"
