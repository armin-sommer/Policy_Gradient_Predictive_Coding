#!/bin/sh
# Strip AI agent attribution trailers from commit messages so no
# agents (Cursor, Claude, Copilot, ...) show up as GitHub contributors.
msg="$1"
[ -f "$msg" ] || exit 0
tmp="${msg}.$$"
grep -viE '^(co-authored-by:.*(cursor|claude|copilot|anthropic|openai|codex|composer)|made.with:?[[:space:]]*cursor)' "$msg" > "$tmp" && mv "$tmp" "$msg"
